{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "http://localhost:5016",
    "Audience": "http://localhost:5016",
    "Key": "daylachuoibimatantoanvaduccungcapboimotchuyenbiagiuathukhoa"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "student-route": {
        "ClusterId": "student-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        }
      },
      "course-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "identity-swagger": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "student-swagger": {
        "ClusterId": "student-cluster",
        "Match": {
          "Path": "/swagger/students/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      },
      "course-swagger": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/swagger/courses/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/v1/swagger.json" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "https": {
            "Address": "https://localhost:7093"
          },
          "http": {
            "Address": "http://localhost:5045"
          }
        }
      },
      "student-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "https": {
            "Address": "https://localhost:7051"
          },
          "http": {
            "Address": "http://localhost:5051"
          }
        }
      },
      "course-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "https": {
            "Address": "https://localhost:7052"
          },
          "http": {
            "Address": "http://localhost:5052"
          }
        }
      }
    }
  }
}
